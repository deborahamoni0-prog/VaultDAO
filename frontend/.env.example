# ─────────────────────────────────────────────
# VaultDAO Frontend — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Deployed Soroban contract address
VITE_CONTRACT_ID=CDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Soroban RPC endpoint
# Testnet:    https://soroban-testnet.stellar.org
# Mainnet:    https://soroban.stellar.org
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase
# Testnet:    Test SDF Network ; September 2015
# Mainnet:    Public Global Stellar Network ; September 2015
VITE_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Human-readable network name used by Freighter wallet (TESTNET | MAINNET)
VITE_STELLAR_NETWORK=TESTNET

# Horizon REST API URL (optional — defaults to testnet)
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar block explorer base URL (optional — defaults to testnet explorer)
VITE_STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet

# Collaborative Editing WebSocket URL
VITE_COLLAB_WS_URL=ws://localhost:1234
